# Phase 1 (waitlist persistence + analytics):

# Required for the waitlist API to persist signups.
DATABASE_URL=
# Optional: override default 10 signups per hour per IP.
# WAITLIST_RATE_LIMIT_PER_HOUR=10

# PostHog analytics (optional — site renders fine without these set).
# When unset, instrumentation-client.ts skips posthog.init() and
# getPostHogClient() returns null. Set in Vercel project env for
# Production / Preview / Development scopes as needed.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
